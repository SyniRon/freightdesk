# Cloudflare Tunnel token — used by the `cloudflared` service to publish the app.
# Get from: https://one.dash.cloudflare.com/ → Networks → Tunnels → Create
# Leave blank if you're not using the bundled tunnel (drop the cloudflared
# service and front the app with your own reverse proxy instead).
TUNNEL_TOKEN=

# ─── Umami analytics ─────────────────────────────────────────────────────
# Random strong password for the Umami postgres DB.
# Generate: openssl rand -hex 24
UMAMI_DB_PASSWORD=

# Application secret for Umami session JWTs.
# Generate: openssl rand -hex 32
UMAMI_APP_SECRET=

# Address to bind the Umami admin UI to. Set this to a private interface
# (loopback, or a VPN/tailnet IP) so the admin UI is reachable only there
# and NOT on the public network. Default 127.0.0.1 = localhost-only.
UMAMI_BIND=127.0.0.1

# Umami website UUID. Plug this in AFTER first deploy:
#   1. With the stack up, visit http://<UMAMI_BIND>:3000
#   2. Log in (default admin/umami; change the password immediately)
#   3. Settings → Websites → Add → name + domain of your deployment
#   4. Copy the generated website UUID here, then redeploy.
VITE_UMAMI_WEBSITE_ID=

# ─── Sentry error monitoring ─────────────────────────────────────────────
# Public DSN for the React bundle. Sentry DSNs are write-only and safe
# to embed in a public bundle — Sentry's spike protection handles abuse.
# Leave blank in dev — no DSN = no events sent, zero overhead. In production
# set it in the deployment's own .env.
VITE_SENTRY_DSN=

# Environment tag for Sentry issues (production / staging / local).
# Defaults to "production" via docker-compose. Override only when you want a
# non-default value (e.g., "local" for privacy-verification testing).
VITE_SENTRY_ENV=
