# Cloudflare Tunnel token for freightdesk.syniron.com
# Get from: https://one.dash.cloudflare.com/ → Networks → Tunnels → Create
# Not needed pre-launch — cloudflared is commented out in docker-compose.yml
# until the in-game contract-window smoke test passes. Until then the app is
# reachable on the Tailscale interface via UMAMI_BIND:8080.
TUNNEL_TOKEN=

# ─── Umami analytics ─────────────────────────────────────────────────────
# Random strong password for the Umami postgres DB.
# Generate: openssl rand -hex 24
UMAMI_DB_PASSWORD=

# Application secret for Umami session JWTs.
# Generate: openssl rand -hex 32
UMAMI_APP_SECRET=

# IP to bind the Umami admin UI to. Use the Tailscale interface IP of this
# host (find via: tailscale ip -4) so the admin UI is reachable only over
# Tailscale and NOT on the public network.
# Default 127.0.0.1 = localhost-only.
UMAMI_BIND=127.0.0.1

# Umami website UUID. Plug this in AFTER first deploy:
#   1. tailscale up; visit http://<synicloud-tailscale-ip>:3000
#   2. Log in (default admin/umami; change immediately)
#   3. Settings → Websites → Add → name "FreightDesk", domain "freightdesk.syniron.com"
#   4. Copy the generated website ID UUID here, then redeploy.
VITE_UMAMI_WEBSITE_ID=
